# ==========================================
# SNIPER BOT V35 — GOLDEN EQUILIBRIUM
# Copia este archivo a .env y rellena tus claves
# ==========================================

# --- BingX API ---
BINGX_API_KEY=your_bingx_api_key_here
BINGX_SECRET_KEY=your_bingx_secret_key_here

# --- Telegram ---
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Estrategia V35 (Sync con TradingView) ---
VOL_MULT=1.5
ADX_MIN=20
LEVERAGE=5
CAPITAL_PCT=2
MAX_TRADES=3
TIME_STOP_MINUTES=45
CANDLE_INTERVAL=3m

# --- Modo ---
# DRY_RUN=true para solo simular sin operar real
DRY_RUN=false
